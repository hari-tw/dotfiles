[user]
	name = Hari Balamani
	email = prabhu.hari.b@gmail.com

# Personal identity's own key. Must come before the includeIf blocks below -
# git processes includeIf inline at its position in the file, so a
# core.sshCommand set AFTER them (e.g. in the main [core] section further
# down) would re-win and override whatever the include just set, every time.
# -F /dev/null bypasses ~/.ssh/config's `Host github.com` block, which
# otherwise silently wins even when a different -i is passed on the command
# line (confirmed by testing directly).
[core]
	sshCommand = "ssh -F /dev/null -i ~/.ssh/id_ed25519_hari-tw -o IdentitiesOnly=yes -o UseKeychain=yes -o AddKeysToAgent=yes"

[includeIf "gitdir:~/Projects/**"]
	path = ~/.gitconfig-work

[includeIf "gitdir:~/SideGigs/**"]
	path = ~/.gitconfig-sidegigs

[github]
  user = hari-tw

[alias]
  br = branch
  cb = "!sh -c 'git branch $1 && git ch $1' -"
  ctb = "!sh -c 'git cb topics/$1' -"

  cm = commit
  co = checkout
  amd = commit --amend
  fc = commit -am 'Initial commit.'
  d = diff
  st = status --short

  graph = log --graph
  last = log -n 10
  commits = "!sh -c 'git log $1 --oneline | cut -d\" \" -f 1 | tr \"\n\" \" \"'"
  url = !git remote -v|sed "'s|.*git[:@]\\(.*\\).git.*|http://\\1|;s|m:|m/|'"|uniq|xargs open
  whois = "!sh -c 'git log -i -1 --pretty=\"format:%an <%ae>\n\" --author=\"$1\"' -"
  discard = checkout -- .
  rmtag = "!sh -c 'git tag -d $1; git push origin :refs/tags/$1'"

  rstatus = !zsh "$HOME/Developer/delta/dotfiles/git-extras/git-rstatus.sh"

  pr = "!f() { git fetch -fu ${2:-origin} refs/pull/$1/head:pr/$1; } ; f"

  # summary, changelog, release, setup, delete-branch, effort, standup,
  # obliterate, fork now come from the real `git-extras` (brew), no alias
  # needed - git auto-discovers any git-xxx binary on $PATH.
  cleanup = delete-merged-branches

[color]
  ui = true

[core]
  editor = cursor --wait
  excludesfile = ~/.gitignore
	autocrlf = false
	compression = 0
  #pager = diff-highlight | less -r

[format]
  pretty = %Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset
  graph = true

[advice]
  statusHints = false

[log]
  abbrevCommit = true

# URL shorthands
# gh:delta/dotfiles
[url "git@github.com:"]
  insteadOf = "gh:"
  pushInsteadOf = "gh:"
  pushInsteadOf = "git://github.com/"

# gist:3928760
[url "git@gist.github.com:"]
  insteadOf = "gist:"
  pushInsteadOf = "gist:"
  pushInsteadOf = "git://gist.github.com/"

[mergetool]
  keepBackup = false
[pull]
	rebase = true

[credential]
  helper = osxkeychain
  default = matching
  
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[http]
	postBuffer = 524288000
	version = HTTP/1.1
